# ============================================================================
# Ho smartvision — Backend FastAPI · Variables de entorno (EJEMPLO)
# Copia este archivo a `.env` y rellena los valores reales. NUNCA lo subas a git.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# URL del proyecto (Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Clave service_role (Settings > API). BYPASSA RLS — mantener en secreto.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...
# Clave anónima (Settings > API). Usada para validar logins.
SUPABASE_ANON_KEY=eyJhbGciOi...anon...
# JWT Secret del proyecto (Settings > API > JWT Settings). Para verificar tokens.
SUPABASE_JWT_SECRET=super-secret-jwt-string-from-supabase

# --- Cifrado de credenciales ONVIF -----------------------------------------
# Genera una clave con:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REEMPLAZA_CON_CLAVE_FERNET_BASE64

# --- Seguridad del Gateway Edge --------------------------------------------
# API key compartida que los gateways (Raspberry Pi) usan para enviar eventos.
GATEWAY_API_KEY=cambia-esta-api-key-larga-y-aleatoria

# --- CORS -------------------------------------------------------------------
# Orígenes permitidos separados por coma (el panel web Next.js).
CORS_ORIGINS=http://localhost:3000,https://tu-panel.vercel.app

# --- Proveedores cloud de cámaras (opcional) --------------------------------
# Permiten streaming sin Raspberry usando las APIs de fabricante.
# Solo hace falta rellenar la marca que uses; si quedan vacías, ese proveedor
# aparece como "no configurado" y el resto de la app sigue funcionando.
#
# EZVIZ Open Platform  ->  https://open.ezviz.com  (crea una app, obtén appKey/appSecret)
EZVIZ_APP_KEY=
EZVIZ_APP_SECRET=
EZVIZ_API_BASE=https://open.ezvizlife.com
#
# Imou / Lechange Open Platform  ->  https://open.imoulife.com  (appId/appSecret)
IMOU_APP_ID=
IMOU_APP_SECRET=
IMOU_API_BASE=https://openapi.easy4ip.com
#
# Reolink y Tapo no usan cloud: se resuelven en LAN/DDNS con IP+usuario+clave
# de la propia cámara (campos ONVIF), sin claves de API.
