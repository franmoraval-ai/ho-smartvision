# ===== Ho smartvision — Panel Web (Next.js) · EJEMPLO =====
# Copia a `.env.local` y rellena. Las NEXT_PUBLIC_* se exponen al navegador.

# URL pública del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Clave anónima de Supabase (pública por diseño)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon...

# URL del backend FastAPI (Railway/Render o local)
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL pública de go2rtc (visor WebRTC/HLS del gateway). Puerto API por defecto: 1984.
# En producción usa el reverse proxy del gateway, p. ej. https://stream.tudominio.com
NEXT_PUBLIC_STREAM_BASE_URL=http://localhost:1984

# Clave PÚBLICA VAPID para Web Push (notificaciones sin Firebase).
# Genera el par con:  npx web-push generate-vapid-keys --json
# La privada NO va aquí: se guarda como secret en la Edge Function de Supabase.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BBJFUfCJpwrtSGDZfdHEpfIYiSwtGsbmfCT0RAZp9kY-HxqB2Y2eieGGxHCreGDiaGJT1cOhQFpCooSmQbJRUgc
