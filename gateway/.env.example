# ============================================================================
# Ho smartvision — Gateway Edge · Variables de entorno (EJEMPLO)
# Copia a `.env` y rellena. Ejecuta en la Raspberry Pi de la propiedad.
# ============================================================================

# Identificador físico único de este gateway.
# Debe estar registrado como `device_id` en la tabla `gateways` (panel web).
GATEWAY_DEVICE_ID=rpi-casa-001

# URL pública del backend FastAPI.
BACKEND_URL=https://ho-smartvision-api.onrender.com

# API key compartida (igual que GATEWAY_API_KEY del backend).
GATEWAY_API_KEY=cambia-esta-api-key-larga-y-aleatoria

# Credenciales ONVIF por defecto de las cámaras (para descubrir RTSP).
ONVIF_USERNAME=admin
ONVIF_PASSWORD=

# Intervalos (segundos).
HEARTBEAT_INTERVAL=30
DISCOVERY_INTERVAL=300
DISCOVERY_TIMEOUT=4

# go2rtc.
GO2RTC_CONFIG_PATH=/etc/go2rtc/go2rtc.yaml
GO2RTC_API_URL=http://127.0.0.1:1984
